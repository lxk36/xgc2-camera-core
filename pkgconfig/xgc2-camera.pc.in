prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: xgc2-camera
Description: ROS-independent XGC2 V4L2 camera capture library
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lxgc2_camera
Cflags: -I${includedir}
